{
  "manifest_version": 3,
  "name": "Audio Summary Plugin",
  "version": "1.8",
  "description": "Summarizes and reads aloud the current page using ChatGPT API",
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "tts"
  ],
  "host_permissions": [
    "https://api.openai.com/*"
  ],
  "background": {
    "service_worker": "src/background.js"
  },
  "action": {
    "default_popup": "src/popup.html",
    "default_icon": {
      "16": "src/icon16.png",
      "32": "src/icon32.png",
      "48": "src/icon48.png",
      "128": "src/icon128.png"
    }
  },
  "options_page": "src/options.html",
  "icons": {
    "16": "src/icon16.png",
    "32": "src/icon32.png",
    "48": "src/icon48.png",
    "128": "src/icon128.png"
  }
}